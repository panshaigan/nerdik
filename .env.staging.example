# Staging environment template for Nerdik.
# Copy to the staging server as `.env`.
# Generate APP_KEY: php artisan key:generate
# See docs/deployment.md for the full deploy checklist.

APP_NAME=Nerdik
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.nerdik.app

# Docker staging (compose.staging.yaml — no local Caddy; prod Caddy routes STAGING_DOMAIN)
APP_DOMAIN=staging.nerdik.app
GITHUB_OWNER=your-github-owner
# CI publishes ghcr.io/${GITHUB_OWNER}/nerdik:<full-git-sha> — not :main. Prefer: IMAGE_TAG=<sha> make staging-deploy
# NERDIK_IMAGE=ghcr.io/${GITHUB_OWNER}/nerdik:<full-git-sha>

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error
LOG_DAILY_DAYS=14

# PostgreSQL (align with your staging database service)
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=nerdik
DB_USERNAME=nerdik
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true

# Trust reverse proxy (Caddy/Nginx/Traefik). Use * behind a single trusted proxy, or comma-separated IPs.
TRUSTED_PROXIES=*

BROADCAST_CONNECTION=reverb

# Server-side Reverb (PHP/worker containers use this hostname)
REVERB_APP_ID=nerdik
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# Browser / Vite Echo — public host where clients open WebSockets (often same domain, wss)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=staging.nerdik.app
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

MEDIA_QUEUE_CONVERSIONS=true
QUEUE_CONVERSIONS_BY_DEFAULT=true

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mailpit (staging only — mail never leaves the VPS)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@staging.nerdik.app"
MAIL_FROM_NAME="${APP_NAME}"

# Mailpit UI auth (username:bcrypt) — generate with:
# docker run --rm axllent/mailpit:latest mailpit bcrypt 'your-secret'
MAILPIT_UI_AUTH=

# Legal pages (Privacy, Terms, Contact)
LEGAL_OPERATOR_NAME="Your Full Name"
LEGAL_OPERATOR_COUNTRY="Poland"
LEGAL_CONTACT_EMAIL="hello@staging.nerdik.app"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

RECAPTCHA_ENABLED=true
# NOCAPTCHA_SITEKEY=
# NOCAPTCHA_SECRET=

TELESCOPE_ENABLED=false
PULSE_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
