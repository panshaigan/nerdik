# Production environment template for Nerdik.
# Copy to the server as `.env` (or `.env.production` if your deploy loads it explicitly).
# Generate on the server host before deploy: echo "APP_KEY=base64:$(openssl rand -base64 32)"
# See docs/deployment.md for the full deploy checklist.

APP_NAME=Nerdik
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

# Docker production (compose.prod.yaml + Caddy)
APP_DOMAIN=your-domain.example
STAGING_DOMAIN=staging.nerdik.app
ACME_EMAIL=you@your-domain.example
GITHUB_OWNER=your-github-owner
# CI publishes ghcr.io/${GITHUB_OWNER}/nerdik:<full-git-sha> — not :main. Prefer: IMAGE_TAG=<sha> make prod-deploy
# NERDIK_IMAGE is resolved automatically on deploy and for make prod-artisan / prod-refresh (see scripts/compose-exec.sh).

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error
LOG_DAILY_DAYS=14

# PostgreSQL (align with your production database service)
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=nerdik
DB_USERNAME=nerdik
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true

# Trust reverse proxy (Caddy/Nginx/Traefik). Use * behind a single trusted proxy, or comma-separated IPs.
TRUSTED_PROXIES=*

BROADCAST_CONNECTION=reverb

# Server-side Reverb (PHP/worker containers use this hostname)
REVERB_APP_ID=nerdik
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# Browser / Vite Echo — public host where clients open WebSockets (often same domain, wss)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=your-domain.example
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

MEDIA_QUEUE_CONVERSIONS=true
QUEUE_CONVERSIONS_BY_DEFAULT=true

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Configure a real mail transport (smtp, ses, postmark, etc.)
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

RECAPTCHA_ENABLED=true
# NOCAPTCHA_SITEKEY=
# NOCAPTCHA_SECRET=

TELESCOPE_ENABLED=false
PULSE_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
