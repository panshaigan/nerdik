# Copy to Caddyfile on the production host and set APP_DOMAIN / STAGING_DOMAIN / ACME_EMAIL in .env.
# Caddy runs only in the prod stack (compose.prod.yaml) and routes staging through nerdik-edge.

{
	email {$ACME_EMAIL}
}

{$APP_DOMAIN} {
	encode gzip

	# Use prod-app / prod-reverb — not "app" / "reverb". Staging also registers
	# "app" on nerdik-edge; Caddy is on that network and would route prod traffic there.
	handle /app/* {
		reverse_proxy prod-reverb:8080
	}

	reverse_proxy prod-app:80
}

{$STAGING_DOMAIN} {
	encode gzip

	handle /app/* {
		reverse_proxy staging-reverb:8080 {
			transport http {
				read_timeout 5s
				dial_timeout 2s
			}
		}
	}

	handle {
		reverse_proxy staging-app:80 {
			transport http {
				read_timeout 5s
				dial_timeout 2s
			}
		}
	}

	handle_errors {
		respond "Staging is offline" 503
	}
}
