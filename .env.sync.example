# Local sync configuration for pulling production data via SSH.
# Copy to .env.sync and fill in values. Never commit .env.sync.
#
# Add the public key to deploy@VPS:
#   ssh-copy-id -i ~/.ssh/nerdik-sync.pub deploy@your.vps.example

SYNC_SSH_HOST=your.vps.example
SYNC_SSH_USER=deploy
SYNC_SSH_KEY=~/.ssh/nerdik-sync

# Paths on the VPS (used by pull-from-prod and prod-to-staging)
SYNC_PROD_PATH=/opt/nerdik
SYNC_STAGING_PATH=/opt/nerdik-staging
