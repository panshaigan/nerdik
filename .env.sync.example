# Local-only sync configuration (SSH pull from VPS). Copy to .env.sync — never commit it.
#
# Not needed on the VPS for prod-to-staging-sync (run directly in /opt/nerdik).
# Only required locally for: make sync-from-prod*, make prod-to-staging-sync-remote
#
# Use an OpenSSH private key under ~/.ssh/ (not a PuTTY .ppk file).
# WSL: do not point at keys on /mnt/c/ — copy or convert into ~/.ssh/ first.
#
# PuTTY .ppk → OpenSSH:
#   puttygen /path/to/key.ppk -O private-openssh -o ~/.ssh/nerdik-sync
#   chmod 600 ~/.ssh/nerdik-sync
#
# Add the public key to deploy@VPS:
#   ssh-copy-id -i ~/.ssh/nerdik-sync.pub -p 22068 deploy@your.vps.example

SYNC_SSH_HOST=your.vps.example
SYNC_SSH_USER=deploy
SYNC_SSH_KEY=~/.ssh/nerdik-sync
# Omit or leave empty for default port 22
SYNC_SSH_PORT=2222

# Paths on the VPS (used by pull-from-prod and prod-to-staging-remote)
SYNC_PROD_PATH=/opt/nerdik
SYNC_STAGING_PATH=/opt/nerdik-staging
