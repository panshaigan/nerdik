# VPS-only backup configuration.
# Copy to /opt/nerdik/.env.backup on the server (never commit real values).
#
# All settings are optional — defaults enable local-only backups with no remote upload.

# Persistent local backup directory on the VPS host.
BACKUP_LOCAL_PATH=/home/deploy/backups/nerdik/prod

# Delete local (and remote, when configured) backups older than this many days.
BACKUP_RETENTION_DAYS=30

# GPG passphrase file for encrypting prod .env (chmod 600, owned by deploy).
# If missing, DB + storage backups still run; .env encryption is skipped.
BACKUP_GPG_PASSPHRASE_FILE=/opt/nerdik/.backup-gpg-passphrase

# rclone remote name — leave empty for local-only mode (no upload, no failure).
# BACKUP_REMOTE_NAME=ovh-nerdik

# Object storage path prefix (only used when BACKUP_REMOTE_NAME is set).
BACKUP_REMOTE_PATH=nerdik-backups/prod

# Prevent overlapping cron runs.
BACKUP_LOCK_FILE=/tmp/nerdik-backup.lock

# Send failure emails via prod MAIL_* to LEGAL_CONTACT_EMAIL (1 = on, 0 = off).
BACKUP_NOTIFY=1
