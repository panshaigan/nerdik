# Local development template for Nerdik (Laravel Sail).
# Copy to .env on first setup: cp .env.example .env && vendor/bin/sail artisan key:generate
# For production/staging deploy variables see .env.production.example and docs/deployment.md.
#
# IMPORTANT: This file is a template only. Never replace an existing working .env with this file.

APP_NAME=Nerdik
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Sail container user/group (Linux/WSL bind mounts)
WWWUSER=1000
WWWGROUP=1000

# PostgreSQL via Sail (see compose.yaml `pgsql` service)
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_ENCRYPT=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Media conversions (avif/webp/jpeg + responsive sizes) are queued by default. PHPUnit sets these to false.
# Requires a queue worker (Sail: `worker` service in compose.yaml).
MEDIA_QUEUE_CONVERSIONS=true
QUEUE_CONVERSIONS_BY_DEFAULT=true
# MEDIA_QUEUE_CONNECTION=
# MEDIA_QUEUE=

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mailpit via Sail (see compose.yaml `mailpit` service)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Legal pages (Privacy, Terms, Contact)
LEGAL_OPERATOR_NAME="Your Full Name"
LEGAL_OPERATOR_COUNTRY="Poland"
LEGAL_CONTACT_EMAIL="hello@example.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

TELESCOPE_ENABLED=true

VITE_APP_NAME="${APP_NAME}"

# Reverb: Docker service name for PHP/queue (see compose.yaml `reverb` service).
REVERB_APP_ID=nerdik
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# Host port published to your machine (default 8081).
FORWARD_REVERB_PORT=8081

# Vite / Echo: the browser connects to the host, not the Docker service DNS name.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8081
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Optional: Google reCAPTCHA v2 (https://www.google.com/recaptcha/admin)
RECAPTCHA_ENABLED=false
NOCAPTCHA_SITEKEY=
NOCAPTCHA_SECRET=

# Optional: Google OAuth (login/register with Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Optional: Facebook OAuth (login/register with Facebook)
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# Docker image publishing / deploy (see docs/ci-cd.md)
GITHUB_OWNER=your-github-owner
