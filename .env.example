# Local development template for nerdik (Laravel Sail).
# Copy to .env on first setup: cp .env.example .env && vendor/bin/sail artisan key:generate
# For production/staging deploy variables see .env.production.example and docs/deployment.md.
#
# IMPORTANT: This file is a template only. Never replace an existing working .env with this file.

# --- Application ---

APP_NAME=nerdik
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# --- Deploy and domains ---

# Deploy/domain vars: see .env.staging.example and .env.production.example
GITHUB_OWNER=your-github-owner
# CI publishes ghcr.io/${GITHUB_OWNER}/nerdik:<full-git-sha> — not :main. Prefer: IMAGE_TAG=<sha> make staging-deploy
# NERDIK_IMAGE=ghcr.io/${GITHUB_OWNER}/nerdik:<full-git-sha>

# --- Localization ---

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# --- Maintenance ---

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# --- PHP and hashing ---

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# --- Sail local containers ---

# Container user/group (Linux/WSL bind mounts)
WWWUSER=1000
WWWGROUP=1000

# Host ports published to your machine (compose.yaml defaults in parentheses)
FORWARD_REVERB_PORT=8081
# FORWARD_DB_PORT=5432
# FORWARD_MAILPIT_PORT=1025
# FORWARD_MAILPIT_DASHBOARD_PORT=8025

# --- Logging ---

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# LOG_DAILY_DAYS=14

# --- Database ---

# PostgreSQL via Sail (see compose.yaml `pgsql` service)
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

# --- Session ---

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true

# --- Reverse proxy ---

# TRUSTED_PROXIES not needed for local development (no TLS-terminating reverse proxy)

# --- Broadcasting and Reverb ---

BROADCAST_CONNECTION=reverb

# Server-side Reverb (Docker service name for PHP/queue — see compose.yaml `reverb` service)
REVERB_APP_ID=nerdik
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# --- Vite frontend ---

# Browser / Echo — connects to the host, not the Docker service DNS name
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8081
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_APP_NAME="${APP_NAME}"

# --- Storage, queue, media, cache ---

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Media conversions are queued by default. PHPUnit sets these to false.
# Requires a queue worker (Sail: `worker` service in compose.yaml).
MEDIA_QUEUE_CONVERSIONS=true
QUEUE_CONVERSIONS_BY_DEFAULT=true
# MEDIA_QUEUE_CONNECTION=
# MEDIA_QUEUE=

CACHE_STORE=database
# CACHE_PREFIX=

# --- Redis ---

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---

# Mailpit via Sail (see compose.yaml `mailpit` service)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Legal pages ---

LEGAL_OPERATOR_NAME="Your Full Name"
LEGAL_OPERATOR_COUNTRY="Poland"
LEGAL_CONTACT_EMAIL="hello@example.com"

# --- AWS / S3 (optional) ---

# Only required if FILESYSTEM_DISK=s3 or media uses S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- OAuth (optional) ---

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# --- reCAPTCHA ---

# Disabled locally so Sail works without Google keys (https://www.google.com/recaptcha/admin)
RECAPTCHA_ENABLED=false
NOCAPTCHA_SITEKEY=
NOCAPTCHA_SECRET=

# --- Telescope and Pulse ---

TELESCOPE_ENABLED=true
PULSE_ENABLED=true
